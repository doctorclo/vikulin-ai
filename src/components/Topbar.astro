---
const { pathname } = Astro.url;
const isWriting = pathname.includes('/posts');
const base = import.meta.env.BASE_URL;
---

<header class="topbar">
  <a href={base} class="brand">Всеволод Викулин</a>
  <nav>
    <a href={`${base}#articles`} class={isWriting ? 'active' : ''}>Статьи</a>
    <a href={`${base}#contacts`}>Контакты</a>
  </nav>
</header>

---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Topbar from '../components/Topbar.astro';

const posts = (await getCollection('posts', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);

const formatDate = (date: Date) => {
  const months = ['янв', 'фев', 'мар', 'апр', 'май', 'июн', 'июл', 'авг', 'сен', 'окт', 'ноя', 'дек'];
  return `${date.getDate()} ${months[date.getMonth()]} ${date.getFullYear()}`;
};
---

<BaseLayout title="Всеволод Викулин">
  <Topbar />

  <section class="intro">
    <p>
      Меня зовут Всеволод Викулин, я 10 лет занимаюсь внедрением AI. Руководил NLP-разработкой ассистента в VK, отвечал за релиз Алисы на Поиск Яндекса, сейчас руковожу разработкой агентов в Т-Банке.
    </p>

    <p>
      Главное, что я понял за свою карьеру:
      успех в AI — не про гениальную архитектуру нейросети, не про терабайты данных и не про тысячи GPU. Успех — это всегда результат большого труда очень скиловой команды.
    </p>

    <p>
      Демку собрать просто. Можно взять готовые API, прикрутить к ним красивый интерфейс и показать на презентации магию. На этом обычно все заканчивается.
      Превратить демку в актив, приносящий прибыль, — несоизмеримо сложнее. Это на рынке умеют не многие.
    </p>

    <p>
      Здесь я пишу, как управляемо внедрять AI в компаниях. Как подходить к выбору процесса, прототипированию и масштабированию итогового решения. Чтобы AI надежно зашел в компанию и там уверенно держался.
    </p>
  </section>

  <hr class="divider" />

  <section id="articles">
    <h2 class="section-label">Статьи</h2>

    {posts.length === 0 ? (
      <p style="color: var(--color-text-secondary); font-size: 14px;">
        Пока пусто. Скоро первая статья.
      </p>
    ) : (
      <div class="posts-list">
        {posts.map((post) => (
          <>
            <span class="post-date">{formatDate(post.data.date)}</span>
            <a href={`/posts/${post.slug}/`} class="post-title">
              {post.data.title}
            </a>
          </>
        ))}
      </div>
    )}
  </section>

  <hr class="divider" />

  <section id="contacts">
    <h2 class="section-label">Контакты</h2>

    <div class="contacts">
      <span class="key">Канал</span>
      <a href="https://t.me/vikulin_ai">t.me/vikulin_ai</a>

      <span class="key">Telegram</span>
      <a href="https://t.me/seva_batareika">t.me/seva_batareika</a>

      <span class="key">Email</span>
      <a href="mailto:va.vikulin@yandex.ru">va.vikulin@yandex.ru</a>
    </div>
  </section>

  <div class="footer">© {new Date().getFullYear()} Всеволод Викулин</div>
</BaseLayout>
